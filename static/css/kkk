    max-width: 220px;
    width: auto;
    white-space: nowrap;
    animation: mapBtnPulse 2s infinite;
}

@keyframes mapBtnPulse {
    0% { transform: translateX(-50%) translateY(0) scale(1); box-shadow: 0 8px 28px rgba(255, 80, 0, 0.45); }
    50% { transform: translateX(-50%) translateY(-2px) scale(1.05); box-shadow: 0 12px 40px rgba(255, 80, 0, 0.65); }
    100% { transform: translateX(-50%) translateY(0) scale(1); box-shadow: 0 8px 28px rgba(255, 80, 0, 0.45); }
}


.map-btn.visible {
    opacity: 1;
    transform: translateY(0);
}

.map-btn.blue {
    background: linear-gradient(90deg, #ff9f43, #ff6a00);
}

.map-instruction {
    background: rgba(0, 0, 0, 0.75);
    color: #fff;
    font-size: 0.78rem;
    padding: 6px 14px;
    border-radius: 999px;
    border: 1px solid rgba(255, 100, 20, 0.2);
}

.map-overlay-container.hidden {
    opacity: 0;
    pointer-events: none;
}

/* ===================== TOAST ===================== */
.hidden { display: none !important; }

.toast-container {
    position: fixed;
    bottom: 18px;
    right: 18px;
    z-index: 2000;
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.toast {
    min-width: 280px;
    background: rgba(14, 8, 5, 0.95);
    border-left: 4px solid var(--ember-core);
    border: 1px solid rgba(255, 100, 20, 0.2);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    animation: slideIn 0.26s ease;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(12px);
}

.toast.success { border-left-color: #4ade80; }
.toast.error   { border-left-color: #e63946; }
.toast.warning { border-left-color: var(--ember-core); }

/* ===================== NOTIFICATIONS ===================== */
.notif-badge {
    position: absolute;
    top: -10px;
    right: -10px;
    background: #ff2222 !important; /* لون أحمر قوي وواضح */
    color: #fff !important;
    font-size: 1.05rem !important; /* أكبر بكثير */
    font-weight: 900;
    padding: 6px 12px;
    border-radius: 50%;
    border: 3px solid #222 !important; /* إطار غامق للوضوح */
    box-shadow: 0 0 12px #ff2222cc;
    opacity: 1 !important; /* إزالة أي شفافية */
    animation: none !important; /* إزالة أي حركة */
    z-index: 10;
    transition: none;
}

.notif-dropdown {
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    width: 360px;
    background: rgba(12, 7, 4, 0.97);
    border: 1px solid rgba(255, 100, 20, 0.15);
    border-radius: var(--radius-md);
    max-height: 380px;
    overflow: auto;
    z-index: 1500;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(20px);
}

.notif-item {
    padding: 12px 14px;
    border-bottom: 1px solid rgba(255, 100, 20, 0.08);
    font-size: 0.86rem;
    transition: background 0.15s ease;
    display: flex;
    gap: 12px;
    align-items: flex-start;
}

.notif-item:hover { background: rgba(255, 100, 20, 0.06); }
.notif-item:last-child { border-bottom: none; }
.notif-item.unread { background: rgba(255, 100, 20, 0.06); }

.notif-icon {
    width: 34px;
    height: 34px;
    min-width: 34px;
    border-radius: 10px;
    display: flex;
    justify-content: center;
    align-items: center;
    background: rgba(255, 106, 0, 0.12);
    border: 1px solid rgba(255, 106, 0, 0.25);
    font-size: 1.1rem;
}

.notif-content { flex: 1; }
.notif-title { font-weight: 700; margin-bottom: 2px; color: var(--text-primary); }
.notif-desc { font-size: 0.84rem; color: var(--text-secondary); margin-bottom: 5px; }
.notif-time { font-size: 0.72rem; color: var(--text-muted); margin-bottom: 8px; }

.notif-header {
    padding: 14px;
    border-bottom: 1px solid rgba(255, 100, 20, 0.08);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(255, 100, 20, 0.03);
}

.notif-header h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 8px;
    border: none;
    padding: 0;
    margin: 0;
    text-transform: none;
}

.notif-count {
    background: var(--ember-core);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 999px;
}

.notif-list { max-height: 340px; overflow-y: auto; }

.notif-action-btn {
    background: transparent;
    border: 1px solid rgba(255, 100, 20, 0.2);
    color: var(--text-primary);
    border-radius: 8px;
    padding: 5px 10px;
    font-size: 0.72rem;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: all 0.2s;
}

.notif-action-btn:hover {
    border-color: var(--ember-core);
    color: var(--ember-bright);
    background: rgba(255, 100, 20, 0.1);
}

.notif-empty {
    padding: 24px;
    text-align: center;
    color: var(--text-muted);
}

.clear-all {
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 0.78rem;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.2s;
}

.clear-all:hover { color: var(--ember-bright); }

/* ===================== INCIDENT MARKERS ===================== */
.weather-widget {
    position: absolute;
    top: 14px;
    right: 14px;
    font-size: 2.1rem;
    z-index: 900;
    opacity: 0;
    transition: all 0.25s ease;
}

.weather-widget.active {
    opacity: 1;
    animation: floatCloud 3s ease-in-out infinite;
}

.incident-fire {
    font-size: 24px;
    line-height: 1;
    filter: drop-shadow(0 0 10px rgba(255, 80, 0, 0.9));
    transform: translateY(-4px);
}

.incident-unit {
    font-size: 22px;
    line-height: 1;
    filter: drop-shadow(0 0 8px rgba(255, 160, 60, 0.8));
    transform: translateY(-4px);
}

.incident-heli {
    font-size: 22px;
    line-height: 1;
    filter: drop-shadow(0 0 8px rgba(255, 200, 80, 0.8));
    transform: translateY(-4px);
