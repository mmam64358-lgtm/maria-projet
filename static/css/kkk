}

@keyframes fire-flicker {
    0% { transform: scale(1) translateY(0); filter: drop-shadow(0 0 10px #ff4e50); }
    100% { transform: scale(1.1) translateY(-3px); filter: drop-shadow(0 0 20px #f9d423); }
}

