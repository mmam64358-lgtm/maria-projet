    font-size: 0.6rem;
    color: rgba(255,255,255,0.3);
    margin-left: 4px;
}

.notif-dropdown-premium {
    position: absolute;
    top: 60px;
    right: 20px;
    width: 350px;
    background: rgba(15, 8, 4, 0.98); /* Deep Ember black */
    backdrop-filter: blur(25px);
    border: 1px solid rgba(255, 106, 0, 0.2); /* Orange accent */
    border-radius: 18px;
    box-shadow: 0 25px 60px rgba(0,0,0,0.8);
    z-index: 2000;
    overflow: hidden;
    animation: fadeIn 0.3s ease;
}

.notif-header-premium {
    padding: 15px 20px;
    border-bottom: 1px solid rgba(255, 106, 0, 0.1);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(255, 106, 0, 0.03);
}

.notif-header-premium h3 {
    margin: 0;
    font-size: 0.95rem;
    color: #ffeb3b; 
}

.notif-item-premium {
    padding: 15px 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
    transition: all 0.2s ease;
    cursor: pointer;
    display: flex;
    gap: 12px;
}

.notif-item-premium:hover {
    background: rgba(255, 106, 0, 0.05);
}

.notif-icon-circle {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 106, 0, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
}

.notif-content {
    flex: 1;
    min-width: 0;
}

.notif-title {
    font-size: 0.85rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 3px;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.notif-desc {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.4;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
}

.notif-item-premium.unread {
    border-left: 3px solid #ff6a00;
    background: rgba(255, 106, 0, 0.04);
}

.notif-action-btn {
    background: rgba(255, 106, 0, 0.15);
    border: 1px solid rgba(255, 106, 0, 0.3);
    color: #ff9f43;
    border-radius: 6px;
    padding: 4px 10px;
    font-size: 0.72rem;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 0.5px;
    transition: all 0.2s ease;
    font-family: inherit;
}

.notif-action-btn:hover {
    background: rgba(255, 106, 0, 0.3);
    color: #fff;
    transform: translateY(-1px);
}

.notif-empty {
    padding: 30px 20px;
    text-align: center;
    color: rgba(255,255,255,0.2);
    font-size: 0.85rem;
}

.notif-list-premium {
    max-height: 360px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,106,0,0.3) transparent;
}

.notif-list-premium::-webkit-scrollbar { width: 4px; }
.notif-list-premium::-webkit-scrollbar-thumb {
    background: rgba(255,106,0,0.3);
    border-radius: 4px;
}

.clear-all {
    background: transparent;
    border: 1px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.4);
    padding: 4px 10px;
    border-radius: 6px;
    font-size: 0.72rem;
    cursor: pointer;
    transition: all 0.2s;
    font-family: inherit;
}

.clear-all:hover {
    border-color: rgba(239,68,68,0.4);
    color: #ef4444;
}

/* Remove the broken duplicate blocks */
.notif-wrapper {
    position: relative;
}

/* ===================== DUPLICATE CLEANUP ===================== */
/* The following overrides any stale duplicate notif styles */

/* --- USER GRID SYSTEM --- */
.user-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    padding: 20px;
}

.user-card-premium {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 25px;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex;
    flex-direction: column;
    align-items: center;
    backdrop-filter: blur(10px);
}

.user-card-premium:hover {
    transform: translateY(-5px);
    border-color: #ff9800;
    box-shadow: 0 15px 35px rgba(255, 152, 0, 0.2);
    background: rgba(255, 255, 255, 0.06);
}

.user-card-avatar {
    width: 85px;
    height: 85px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid rgba(255, 106, 0, 0.3);
    margin-bottom: 15px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.5);
    transition: 0.3s;
}

.user-card-premium:hover .user-card-avatar {
    border-color: #f9d423;
    transform: scale(1.05);
}

.user-card-name {
    font-size: 1.15rem;
    font-weight: 800;
    color: #fff;
    margin-bottom: 4px;
    letter-spacing: -0.3px;
}

.user-card-email {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.4);
    margin-bottom: 15px;
}

.user-role-badge {
    padding: 6px 14px;
    border-radius: 12px;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 20px;
    border: 1px solid transparent;
}

.user-role-badge.admin {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border-color: rgba(239, 68, 68, 0.2);
}

.user-role-badge.fireman {
    background: rgba(249, 115, 22, 0.1);
    color: #f97316;
    border-color: rgba(249, 115, 22, 0.2);
}

.user-role-badge.citizen {
    background: rgba(255, 255, 255, 0.05);
    color: #aaa;
    border-color: rgba(255, 255, 255, 0.1);
}

.user-card-stats {
    width: 100%;
    display: flex;
    justify-content: space-between;
    padding-top: 15px;
    border-top: 1px solid rgba(255,255,255,0.05);
}

.user-stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
}

.user-stat-item small {
    font-size: 0.65rem;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.user-stat-item strong {
    font-size: 0.85rem;
    color: #fff;
}

/* --- LEAFLET UI FIXES --- */
.fire-map-icon {
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    display: flex;
    justify-content: center;
    align-items: center;
}

#algo-plan-details {
    max-height: 400px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: #00ff88 transparent;
    padding: 15px;
    text-shadow: 0 0 5px rgba(0, 255, 136, 0.4);
    background: rgba(0, 0, 0, 0.2);
    border-radius: 8px;
    margin-top: 10px;
}

#algo-plan-details::-webkit-scrollbar {
    width: 6px;
}

#algo-plan-details::-webkit-scrollbar-thumb {
    background-color: #00ff88;
    border-radius: 10px;
}
