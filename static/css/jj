    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
}

.stat-card .value {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--ember-bright);
    text-shadow: 0 0 10px rgba(255, 159, 67, 0.3);
}

.map-view-hero {
    width: 100%;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(249, 212, 35, 0.3);
